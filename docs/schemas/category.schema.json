{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Category",
  "type": "object",
  "required": ["name", "display_name", "products"],
  "additionalProperties": false,
  "properties": {
    "name": { "type": "string", "pattern": "^[a-z0-9_]+$" },
    "display_name": { "type": "string", "minLength": 1 },
    "strapline": { "type": "string" },
    "weights": {
      "type": "object",
      "required": ["adopt", "cap"],
      "additionalProperties": false,
      "properties": { "adopt": { "type": "number" }, "cap": { "type": "number" } }
    },
    "scoring_recipe": { "type": "object" },
    "products": { "type": "array", "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" } },
    "comments": { "type": "array", "items": { "type": "string" } }
  }
}
