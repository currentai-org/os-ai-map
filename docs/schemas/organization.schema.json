{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Organization",
  "type": "object",
  "required": ["name", "display_name", "products"],
  "additionalProperties": false,
  "properties": {
    "name": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "display_name": { "type": "string", "minLength": 1 },
    "type": { "enum": ["company", "lab", "foundation", "individual", "government", "unknown"] },
    "homepage": { "type": "string" },
    "country": { "type": "string" },
    "github": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["url"],
        "additionalProperties": false,
        "properties": { "url": { "type": "string", "pattern": "^https?://" } }
      }
    },
    "products": { "type": "array", "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" } },
    "comments": { "type": "string" }
  }
}
